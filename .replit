modules = ["php-8.2", "web", "bash", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3306
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
TYPO3_DB_HOST = "localhost"
TYPO3_DB_PORT = "3306"
TYPO3_DB_DBNAME = "typo3_dentist"
TYPO3_DB_USER = "typo3"
TYPO3_DB_PASSWORD = "typo3secret"
TYPO3_CONTEXT = "Development"
TYPO3_ENCRYPTION_KEY = "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"
TYPO3_MAIL_TRANSPORT = "sendmail"
TYPO3_DB_SOCKET = "/tmp/mysql.sock"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start.sh"]
