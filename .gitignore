# Git ignore patterns for TYPO3 Docker project

# Environment
.env
.env.local
.env.*.local


# Composer dependencies
/vendor/
/bin/

# TYPO3 specific
var/
fileadmin/
typo3conf/
typo3temp/
public/index.php
public/typo3/

# Logs & cache
*.log
.phpunit.result.cache

# IDE
.idea/

# Node (if using frontend tools)
node_modules/
npm-debug.log
yarn-error.log

# Build artifacts
dist/
build/